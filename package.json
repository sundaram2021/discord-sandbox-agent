{
  "name": "sandbox-agent",
  "version": "0.0.1",
  "description": "AI sandbox agent with Anthropic + TensorLake code execution",
  "type": "module",
  "scripts": {
    "start": "node src/index.ts",
    "dev": "node --watch src/index.ts",
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix"
  },
  "keywords": [
    "tensorlake",
    "sandbox",
    "agent",
    "anthropic"
  ],
  "author": "sundaram2021",
  "license": "ISC",
  "packageManager": "pnpm@10.15.1",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "tensorlake": "^0.5.46",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
